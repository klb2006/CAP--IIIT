# ========================================
# Water Tank Monitoring System - Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values

# ========================================
# DATABASE CONFIGURATION (Aiven PostgreSQL)
# ========================================
DB_HOST=your_database_host.aivencloud.com
DB_PORT=24446
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your_database_password_here
DB_SSLMODE=require

# ========================================
# API CONFIGURATION
# ========================================
# Backend API URL (for local development)
VITE_API_URL=http://localhost:8000

# Frontend URL (used by backend for CORS)
FRONTEND_URL=http://localhost:5173

# ========================================
# THINGSPEAK API CONFIGURATION
# ========================================
# Your ThingSpeak Channel ID and API Key
THINGSPEAK_CHANNEL_ID=3290444
THINGSPEAK_API_KEY=AWP8F08WA7SLO5EQ

# ========================================
# ML MODEL CONFIGURATION
# ========================================
MODEL_PATH=saved_models/best_model.h5

# ========================================
# RENDER.COM DEPLOYMENT
# ========================================
# When deploying on Render, update these values:
# DB_HOST=your-database-host.aivencloud.com
# VITE_API_URL=https://your-backend.onrender.com
# FRONTEND_URL=https://your-frontend.onrender.com

